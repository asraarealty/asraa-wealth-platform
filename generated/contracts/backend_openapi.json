{
  "openapi": "3.0.3",
  "info": {
    "title": "Asraa Wealth Backend API",
    "version": "1.0.0"
  },
  "paths": {
    "/clients": {
      "get": { "tags": ["client"] },
      "post": {
        "tags": ["client"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        }
      }
    },
    "/clients/admin": {
      "get": { "tags": ["admin", "client"] }
    },
    "/clients/{id}": {
      "get": {
        "tags": ["client"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }]
      },
      "patch": {
        "tags": ["client"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["client"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }]
      }
    },
    "/clients/{id}/status": {
      "patch": {
        "tags": ["client"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["status"],
                "properties": {
                  "status": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "/clients/{id}/archive": {
      "post": {
        "tags": ["client"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }]
      }
    },
    "/clients/{id}/restore": {
      "patch": {
        "tags": ["client"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }]
      }
    },
    "/clients/{id}/permanent": {
      "delete": {
        "tags": ["client"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }]
      }
    },
    "/assets": {
      "post": {
        "tags": ["portfolio"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        }
      }
    },
    "/assets/{id}": {
      "put": {
        "tags": ["portfolio"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }]
      },
      "delete": {
        "tags": ["portfolio"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }]
      }
    },
    "/assets/admin": {
      "get": { "tags": ["admin", "portfolio"] },
      "post": {
        "tags": ["admin", "portfolio"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        }
      }
    },
    "/assets/admin/{id}": {
      "patch": {
        "tags": ["admin", "portfolio"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }]
      },
      "delete": {
        "tags": ["admin", "portfolio"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }]
      }
    },
    "/transactions": {
      "get": {
        "tags": ["portfolio"],
        "parameters": [
          { "name": "client_id", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "page", "in": "query", "required": false, "schema": { "type": "integer", "nullable": true } },
          { "name": "limit", "in": "query", "required": false, "schema": { "type": "integer", "nullable": true } }
        ]
      }
    },
    "/insights": {
      "get": {
        "tags": ["intelligence"],
        "parameters": [
          { "name": "client_id", "in": "query", "required": false, "schema": { "type": "integer" } }
        ]
      }
    },
    "/insights/me": {
      "get": {
        "tags": ["intelligence"]
      }
    }
  }
}
