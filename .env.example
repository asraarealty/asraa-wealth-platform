# Server-side URL of the FastAPI backend used by Next.js rewrites.
# All /api/v2/* requests are proxied through the Next.js server to this URL,
# eliminating cross-origin (CORS) issues and keeping cookies same-origin.
#
# Local development:  BACKEND_URL=http://localhost:8000
# Production:         BACKEND_URL=https://api.asraarealty.in  (set in Vercel)
BACKEND_URL=http://localhost:8000

# Leave NEXT_PUBLIC_API_URL empty. The rewrites above handle routing so that
# browser requests always go to the same origin (app.asraarealty.in in prod).
# Only set this if you are intentionally bypassing rewrites and calling the
# backend directly from the browser (requires correct CORS on the backend).
NEXT_PUBLIC_API_URL=
