# Server-side URL of the FastAPI backend used by Next.js rewrites.
# All /api/v2/* requests are proxied through the Next.js server to this URL,
# eliminating cross-origin (CORS) issues and keeping cookies same-origin.
#
# Local development:  BACKEND_URL=http://localhost:8000
# Production:         BACKEND_URL=https://api.asraarealty.in  (set in Vercel)
BACKEND_URL=http://localhost:8000

# Public API base URL used by the browser to call the FastAPI backend directly.
# In production this should be set to the live backend URL.
# Local development: leave empty to use the default fallback (https://api.asraarealty.in),
# or set to http://localhost:8000 to point at a local instance.
NEXT_PUBLIC_API_URL=https://api.asraarealty.in
