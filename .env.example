# Server-side URL of the FastAPI backend used by Next.js rewrites.
# All /api/v2/* and /auth/* requests are proxied through the Next.js server to
# this URL, eliminating cross-origin (CORS) issues and keeping cookies same-origin.
#
# Local development:  BACKEND_URL=http://localhost:8000
# Production:         BACKEND_URL=https://api.asraarealty.in  (set in Vercel)
BACKEND_URL=http://localhost:8000

# Sentry DSN for error tracking.
# Obtain from https://sentry.io → Project Settings → Client Keys (DSN).
# SENTRY_DSN is used server-side; NEXT_PUBLIC_SENTRY_DSN is exposed to the browser.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
