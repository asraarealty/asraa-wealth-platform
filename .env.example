# Server-side URL of the FastAPI backend used by Next.js rewrites.
# All /api/* requests are proxied through the Next.js server to this URL,
# eliminating cross-origin (CORS) issues and keeping cookies same-origin.
#
# Local development:  BACKEND_URL=http://localhost:8000
# Production (Vercel): set BACKEND_URL=https://api.asraarealty.in
#
# IMPORTANT: This must be set in the Vercel environment variables dashboard for
# production. Without it, API calls will fall back to localhost:8000 and fail.
BACKEND_URL=http://localhost:8000

# Expose the API base URL to the browser (e.g. for client-side health checks).
# If set, next.config.js also uses it as a server-side fallback when BACKEND_URL
# is absent — both variables are read at build/startup time by next.config.js.
# NEXT_PUBLIC_API_URL=https://api.asraarealty.in
